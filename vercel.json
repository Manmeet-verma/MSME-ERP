{
  "installCommand": "cd artifacts/quotation-app && npm install",
  "buildCommand": "cd artifacts/quotation-app && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/quotation-app/dist",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://msme-erp-api-3s11.onrender.com/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/((?!api/|assets/|favicon|robots|manifest|sw\\.js|workbox|icons|logo).*)",
      "destination": "/index.html"
    }
  ]
}
