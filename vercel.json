{
  "installCommand": "cd artifacts/quotation-app && npm install",
  "buildCommand": "cd artifacts/quotation-app && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/quotation-app/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://msme-erp-api.onrender.com/api/:path*"
    }
  ]
}
