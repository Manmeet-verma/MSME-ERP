{
  "installCommand": "cd artifacts/quotation-app && npm install",
  "buildCommand": "cd artifacts/quotation-app && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/quotation-app/dist",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/((?!assets/|api/|favicon|robots|manifest|sw\\.js|workbox|icons|logo).*)",
      "destination": "/index.html"
    }
  ]
}
